generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Item {
  id            String    @id @default(uuid())
  type          String
  text          String
  context       String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  status        String?
  nextStep      String?
  blockedReason String?
  doneAt        DateTime?

  @@map("items")
}
