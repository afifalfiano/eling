generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  items     Item[]
}

model Item {
  id            String    @id @default(uuid())
  userId        String?
  sessionId     String?
  user          User?     @relation(fields: [userId], references: [id])
  type          String
  text          String
  context       String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  status        String?
  nextStep      String?
  blockedReason String?
  doneAt        DateTime?

  @@index([userId])
  @@index([sessionId])
  @@map("items")
}
