# Copy to .env on the VPS and fill in real values.
# Never commit .env to git.

DOMAIN=eling.pipdev.net
POSTGRES_PASSWORD=changeme_strongpassword
AUTH_USERNAME=yourUsername

# Generate hash with:
# node -e "const b=require('bcryptjs'); b.hash('yourPassword',12).then(h=>console.log(Buffer.from(h).toString('base64')))"
AUTH_PASSWORD_HASH=base64encodedBcryptHash

# Generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=128charRandomHex
